---
export const prerender = true

import AppLayout from "@/layouts/app.astro"
import { AdminUsers } from "@/components/admin-users"
---

<AppLayout
  title="Admin Users | Project Orbit Astro"
  description="Kelola user developer."
  pageTitle="Admin Users"
>
  <section class="grid gap-6">
    <div class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">
        User Directory
      </p>
      <h2 class="mt-2 font-serif text-2xl font-semibold text-slate-900">
        Semua user yang terdaftar.
      </h2>
      <p class="mt-3 text-sm text-slate-600">
        Admin dapat melihat semua user dan role mereka.
      </p>
    </div>
    <AdminUsers client:load />
  </section>
</AppLayout>
