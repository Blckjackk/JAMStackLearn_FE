---
export const prerender = true

import MainLayout from "@/layouts/main.astro"

const supportEmail =
  import.meta.env.PUBLIC_SUPPORT_EMAIL ?? "support@example.com"
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "Project Orbit"
---

<MainLayout
  title={`Data Deletion | ${siteName}`}
  description={`Instruksi penghapusan data dan akun untuk ${siteName}.`}
>
  <main
    class="relative isolate overflow-hidden bg-[#f8fafc] px-6 py-16 sm:py-20"
  >
    <div
      class="absolute inset-0 -z-10"
      style="background: radial-gradient(circle at top left, rgba(15, 23, 42, 0.08), transparent 30%), radial-gradient(circle at top right, rgba(56, 189, 248, 0.16), transparent 28%), linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);"
    >
    </div>
    <div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
      <section
        class="rounded-3xl border border-white/80 bg-white/90 p-8 shadow-[0_24px_80px_-40px_rgba(15,23,42,0.45)] backdrop-blur"
      >
        <p
          class="text-xs font-semibold tracking-[0.32em] text-sky-700 uppercase"
        >
          User Data Deletion
        </p>
        <h1
          class="mt-3 font-serif text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl"
        >
          Request penghapusan akun dan data
        </h1>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
          Pengguna {siteName} dapat meminta penghapusan akun beserta data pribadi
          yang tersimpan di sistem kami. Kami memproses permintaan secara manual setelah
          verifikasi identitas pemilik akun.
        </p>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"
            >
              Cara request
            </p>
            <ol class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
              <li>
                1. Kirim email ke {supportEmail} dengan subjek "Delete My Data".
              </li>
              <li>2. Sertakan alamat email akun yang ingin dihapus.</li>
              <li>
                3. Tim kami akan verifikasi permintaan sebelum menghapus data.
              </li>
            </ol>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"
            >
              Apa yang dihapus
            </p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
              <li>• Data profil akun</li>
              <li>• Data login dan identitas yang tersimpan</li>
              <li>• Data project, invite, dan relasi pengguna terkait akun</li>
            </ul>
          </div>
        </div>

        <div
          class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-950"
        >
          <p class="font-semibold">Waktu pemrosesan</p>
          <p class="mt-1">
            Permintaan penghapusan akan diproses maksimal 3x24 jam setelah
            verifikasi selesai. Sebagian data dapat tetap disimpan jika
            diwajibkan oleh kebijakan keamanan atau hukum yang berlaku.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={`mailto:${supportEmail}?subject=Delete%20My%20Data`}
            class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-slate-800"
          >
            Email support
          </a>
          <a
            href="/privacy-policy"
            class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
          >
            Lihat Privacy Policy
          </a>
        </div>
      </section>

      <section
        class="grid gap-4 rounded-3xl border border-slate-200 bg-white/80 p-6 shadow-sm sm:grid-cols-3"
      >
        <div>
          <p
            class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"
          >
            Email kontak
          </p>
          <p class="mt-2 text-sm font-medium text-slate-900">{supportEmail}</p>
        </div>
        <div>
          <p
            class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"
          >
            Halaman publik
          </p>
          <p class="mt-2 text-sm font-medium text-slate-900">/data-deletion</p>
        </div>
        <div>
          <p
            class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"
          >
            Status
          </p>
          <p class="mt-2 text-sm font-medium text-emerald-700">
            Siap dipakai untuk review Meta
          </p>
        </div>
      </section>
    </div>
  </main>
</MainLayout>
