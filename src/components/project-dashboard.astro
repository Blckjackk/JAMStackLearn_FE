---
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { UserAvatar } from "@/components/user-avatar"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import {
  Empty,
  EmptyContent,
  EmptyDescription,
  EmptyHeader,
  EmptyTitle,
} from "@/components/ui/empty"
import { Separator } from "@/components/ui/separator"
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table"
import type { Project, User } from "@/types"

interface Props {
  projects: Project[]
  activeUser: User | null
  activeUserId: number
  loadError: string | null
}

const { projects, activeUser, activeUserId, loadError } = Astro.props

const dateFormatter = new Intl.DateTimeFormat("id-ID", {
  day: "2-digit",
  month: "short",
  year: "numeric",
})

const describedProjects = projects.filter(
  (project) => project.description.trim().length > 0
)
const recentProjects = projects.filter((project) => {
  const createdAt = new Date(project.createdAt)
  if (Number.isNaN(createdAt.getTime())) {
    return false
  }

  const THIRTY_DAYS = 1000 * 60 * 60 * 24 * 30
  return Date.now() - createdAt.getTime() <= THIRTY_DAYS
})

const latestProjects = [...projects]
  .sort(
    (left, right) =>
      new Date(right.createdAt).getTime() - new Date(left.createdAt).getTime()
  )
  .slice(0, 3)

const formatDate = (value: string) => {
  const date = new Date(value)
  return Number.isNaN(date.getTime())
    ? "Tanggal belum tersedia"
    : dateFormatter.format(date)
}

const getInitials = (username?: string) => {
  if (!username) {
    return `U${activeUserId}`
  }

  return username
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("")
}

const userLabel = activeUser?.username ?? `User #${activeUserId}`
---

<main class="relative isolate overflow-hidden">
  <div
    class="absolute inset-x-0 top-0 -z-10 h-136 bg-[radial-gradient(circle_at_top_left,rgba(15,23,42,0.12),transparent_38%),radial-gradient(circle_at_top_right,rgba(148,163,184,0.18),transparent_28%),linear-gradient(180deg,rgba(248,250,252,0.96),rgba(255,255,255,0.7))]"
  >
  </div>

  <section
    class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-6 py-10 lg:px-8 lg:py-16"
  >
    <div class="grid gap-6 lg:grid-cols-[1.4fr_0.9fr] lg:items-start">
      <div class="space-y-6">
        <div class="flex flex-wrap items-center gap-3">
          <Badge>Astro SSR</Badge>
          <Badge variant="outline">shadcn/ui</Badge>
          <Badge variant="outline">ASP.NET API</Badge>
        </div>

        <div class="max-w-3xl space-y-4">
          <p
            class="text-sm font-medium tracking-[0.25em] text-muted-foreground uppercase"
          >
            Workspace overview
          </p>
          <h1
            class="max-w-3xl font-serif text-4xl leading-tight font-semibold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
          >
            Kelola project dengan tampilan Astro yang lebih siap pakai.
          </h1>
          <p
            class="max-w-2xl text-base leading-8 text-muted-foreground sm:text-lg"
          >
            Halaman ini mengambil data project berdasarkan user aktif, lalu
            menampilkannya sebagai dashboard ringkas yang lebih layak daripada
            list sederhana.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            class={buttonVariants({ variant: "default", size: "lg" })}
            href={`/?userId=${activeUserId}`}
          >
            Refresh current user
          </a>
          <a
            class={buttonVariants({ variant: "outline", size: "lg" })}
            href="/?userId=1"
          >
            Lihat user #1
          </a>
        </div>

        {
          loadError && (
            <Alert
              className="max-w-2xl border-destructive/30 bg-destructive/5"
              variant="destructive"
            >
              <AlertTitle>API belum mengembalikan data lengkap</AlertTitle>
              <AlertDescription>{loadError}</AlertDescription>
            </Alert>
          )
        }
      </div>

      <Card
        className="border border-border/60 bg-background/85 shadow-sm backdrop-blur"
      >
        <CardHeader className="gap-4">
          <div class="flex items-center gap-3">
            <UserAvatar
              initials={getInitials(activeUser?.username)}
              size="lg"
            />
            <div class="space-y-1">
              <CardTitle className="text-xl">{userLabel}</CardTitle>
              <CardDescription>
                {
                  activeUser?.email ??
                    `Profil user belum tersedia. Gunakan query ?userId=${activeUserId} atau jalankan backend API.`
                }
              </CardDescription>
            </div>
          </div>
        </CardHeader>
        <CardContent className="space-y-5">
          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-border/60 bg-muted/40 p-4">
              <p class="text-sm text-muted-foreground">Total project</p>
              <p class="mt-2 text-3xl font-semibold tracking-tight">
                {projects.length}
              </p>
            </div>
            <div class="rounded-2xl border border-border/60 bg-muted/40 p-4">
              <p class="text-sm text-muted-foreground">Project dengan brief</p>
              <p class="mt-2 text-3xl font-semibold tracking-tight">
                {describedProjects.length}
              </p>
            </div>
            <div class="rounded-2xl border border-border/60 bg-muted/40 p-4">
              <p class="text-sm text-muted-foreground">
                Dibuat 30 hari terakhir
              </p>
              <p class="mt-2 text-3xl font-semibold tracking-tight">
                {recentProjects.length}
              </p>
            </div>
            <div class="rounded-2xl border border-border/60 bg-muted/40 p-4">
              <p class="text-sm text-muted-foreground">User aktif</p>
              <p class="mt-2 text-3xl font-semibold tracking-tight">
                #{activeUserId}
              </p>
            </div>
          </div>
          <Separator />
          <div class="space-y-2">
            <p class="text-sm font-medium text-foreground">
              Kontrak backend yang dipakai
            </p>
            <p class="text-sm leading-6 text-muted-foreground">
              Index ini mengikuti endpoint GET
              /api/project/user/&#123;userId&#125; dan GET
              /api/user/&#123;id&#125;. Jika API belum hidup, halaman tetap
              tampil dengan state error yang eksplisit.
            </p>
          </div>
        </CardContent>
      </Card>
    </div>

    <section class="grid gap-6 xl:grid-cols-[1.25fr_0.75fr]">
      <Card className="border border-border/60 bg-background/90 shadow-sm">
        <CardHeader>
          <CardTitle className="text-2xl">Project snapshot</CardTitle>
          <CardDescription>
            Ringkasan project terbaru untuk user aktif, ditata sebagai kartu
            supaya lebih cepat dipindai.
          </CardDescription>
        </CardHeader>
        <CardContent>
          {
            latestProjects.length > 0 ? (
              <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                {latestProjects.map((project) => (
                  <div class="rounded-3xl border border-border/60 bg-muted/25 p-5">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="text-lg font-semibold tracking-tight">
                          {project.name}
                        </p>
                        <p class="mt-1 text-sm text-muted-foreground">
                          Project #{project.id}
                        </p>
                      </div>
                      <Badge variant="secondary">User {project.userId}</Badge>
                    </div>
                    <p class="mt-4 line-clamp-4 text-sm leading-6 text-muted-foreground">
                      {project.description.trim() ||
                        "Belum ada deskripsi project. Anda bisa menambahkan brief agar card ini lebih informatif."}
                    </p>
                    <div class="mt-5 flex items-center justify-between text-sm">
                      <span class="text-muted-foreground">Created</span>
                      <span class="font-medium text-foreground">
                        {formatDate(project.createdAt)}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <Empty className="border border-dashed border-border/70 bg-muted/20">
                <EmptyHeader>
                  <EmptyTitle>Belum ada project untuk user ini</EmptyTitle>
                  <EmptyDescription>
                    Coba ganti userId di query string atau jalankan backend agar
                    daftar project bisa diambil dari API.
                  </EmptyDescription>
                </EmptyHeader>
                <EmptyContent>
                  <a
                    class={buttonVariants({ variant: "outline" })}
                    href="/?userId=1"
                  >
                    Buka user default
                  </a>
                </EmptyContent>
              </Empty>
            )
          }
        </CardContent>
      </Card>

      <Card className="border border-border/60 bg-background/90 shadow-sm">
        <CardHeader>
          <CardTitle className="text-2xl">Operational notes</CardTitle>
          <CardDescription>
            Ringkasan keputusan implementasi supaya halaman ini tetap nyambung
            ke struktur backend dan mudah dikembangkan.
          </CardDescription>
        </CardHeader>
        <CardContent
          className="space-y-4 text-sm leading-6 text-muted-foreground"
        >
          <div class="rounded-2xl border border-border/60 bg-muted/30 p-4">
            <p class="font-medium text-foreground">Service alignment</p>
            <p class="mt-2">
              Front-end sekarang memakai endpoint singular sesuai controller
              backend: project/... dan user/....
            </p>
          </div>
          <div class="rounded-2xl border border-border/60 bg-muted/30 p-4">
            <p class="font-medium text-foreground">Type safety</p>
            <p class="mt-2">
              Type Project dan User diselaraskan dengan DTO backend agar render
              card, metadata, dan identitas user tidak meleset.
            </p>
          </div>
          <div class="rounded-2xl border border-border/60 bg-muted/30 p-4">
            <p class="font-medium text-foreground">Next implementation</p>
            <p class="mt-2">
              Langkah natural berikutnya adalah membuat project detail page yang
              memuat task list dari endpoint GET
              /api/task/project/&#123;projectId&#125;.
            </p>
          </div>
        </CardContent>
      </Card>
    </section>

    <Card className="border border-border/60 bg-background/90 shadow-sm">
      <CardHeader>
        <CardTitle className="text-2xl">Project register</CardTitle>
        <CardDescription>
          Versi tabel untuk membantu scanning cepat terhadap seluruh project
          yang berhasil diambil.
        </CardDescription>
      </CardHeader>
      <CardContent>
        {
          projects.length > 0 ? (
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Project</TableHead>
                  <TableHead>User ID</TableHead>
                  <TableHead>Description</TableHead>
                  <TableHead className="text-right">Created at</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {projects.map((project) => (
                  <TableRow>
                    <TableCell className="font-medium text-foreground">
                      {project.name}
                    </TableCell>
                    <TableCell>{project.userId}</TableCell>
                    <TableCell className="max-w-xs truncate text-muted-foreground">
                      {project.description.trim() || "No description yet"}
                    </TableCell>
                    <TableCell className="text-right">
                      {formatDate(project.createdAt)}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          ) : (
            <div class="rounded-2xl border border-dashed border-border/70 bg-muted/20 p-6 text-sm text-muted-foreground">
              Tidak ada data project untuk ditampilkan di tabel.
            </div>
          )
        }
      </CardContent>
    </Card>
  </section>
</main>
